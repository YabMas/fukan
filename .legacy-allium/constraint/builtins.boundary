fn in(x: Any, s: Set<Any>) -> Bool
    -- Set membership.

fn contains(haystack: String, needle: String) -> Bool
    -- Substring containment. False for non-string inputs.

fn is_present(x: Any) -> Bool
    -- True iff x is non-nil.

fn is_absent(x: Any) -> Bool
    -- True iff x is nil.
