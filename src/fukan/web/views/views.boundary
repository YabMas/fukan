-- boundary: 1

-- Views subsystem — projection + Cytoscape rendering + HTML shell, sidebar,
-- breadcrumb. All cross-wall callables are fn-declared and thus implicitly
-- exposed; no additional exports needed at the subsystem boundary.

subsystem views {
    contains:
        ./graph.allium
        ./cytoscape.allium
        ./shell.allium
        ./sidebar.allium
        ./projection.allium
        ./breadcrumb.allium

    exports:
}
