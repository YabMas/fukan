-- allium: 2
-- model.allium
--
-- Scope: System model — the structured representation of a system combining
--   specification and implementation
-- Includes: Node hierarchy, edge semantics, module boundaries,
--   structural invariants, spec/impl realization states
-- Excludes:
--   - Build pipeline and analysis (see model/pipeline.allium)
--   - Language-specific analyzers (see model/languages specs)
--   - Infrastructure lifecycle (see infra/spec.allium)
--   - Projection and filtering (see projection.allium)
--   - View rendering and interaction (see views.allium)
--
-- Design context:
--   The model represents three realization states:
--   - Spec-only: design-phase modules with descriptions, boundary
--     declarations, and spec-derived function nodes — but no implementation.
--   - Spec + impl: the richest nodes. Spec provides purpose and boundaries;
--     implementation provides concrete structure.
--   - Impl-only: imperative shell modules that don't need specs. Populated
--     from code analysis alone — thinner but perfectly valid.
--
--   At the default view level, spec-only and spec+impl look the same: you
--   see the module's description, its public API (as function children),
--   and its owned data shapes. The only difference is that implemented
--   modules can be expanded to reveal their internal structure.

------------------------------------------------------------
-- Type Expression IR
------------------------------------------------------------

value MapEntry {
    -- A single field in a map type expression.
    key: String
    optional: Boolean
    type: TypeExpr
    description: String?
}

entity TypeExpr {
    -- A generic, language-agnostic type expression.
    -- Produced by language analyzers at build time. Consumed by
    -- projection (reference extraction) and views (rendering).
    -- Replaces raw Malli forms — only the Clojure analyzer knows Malli.
    --
    -- Keyword classification for refs vs primitives:
    --   uppercase-initial (:Model, :NodeId) → ref tag
    --   lowercase (:string, :int, :any)     → primitive tag
    -- The projection layer filters refs against the schema registry,
    -- so false positives are harmless.

    tag: ref | primitive | map | map_of | vector | set
       | maybe | or | and | enum | tuple | fn | predicate | unknown
    description: String?
}

variant RefExpr : TypeExpr {
    -- Named reference to another type (e.g. :Model, :NodeId).
    -- The name is an identifier (registry key), not an arbitrary string.
    -- In Clojure, this maps to a keyword.
    name: Identifier
}

variant PrimitiveExpr : TypeExpr {
    -- Built-in primitive type (e.g. "string", "int", "any").
    name: String
}

variant MapExpr : TypeExpr {
    -- Structured map with named, typed entries.
    entries: List<MapEntry>
}

variant MapOfExpr : TypeExpr {
    -- Homogeneous map from key type to value type.
    key_type: TypeExpr
    value_type: TypeExpr
}

variant VectorExpr : TypeExpr {
    -- Homogeneous ordered collection.
    element: TypeExpr
}

variant SetExpr : TypeExpr {
    -- Homogeneous unordered collection.
    element: TypeExpr
}

variant MaybeExpr : TypeExpr {
    -- Optional/nullable wrapper.
    inner: TypeExpr
}

variant OrExpr : TypeExpr {
    -- Union of type alternatives.
    variants: List<TypeExpr>
}

variant AndExpr : TypeExpr {
    -- Intersection of type constraints.
    types: List<TypeExpr>
}

variant EnumExpr : TypeExpr {
    -- Fixed set of literal values.
    -- Values may be strings, keywords, numbers, or other literals
    -- depending on the source language.
    values: List<Value>
}

variant TupleExpr : TypeExpr {
    -- Fixed-length heterogeneous sequence.
    elements: List<TypeExpr>
}

variant FnExpr : TypeExpr {
    -- Function type (in type position, not FunctionSignature).
    inputs: List<TypeExpr>
    output: TypeExpr
}

variant PredicateExpr : TypeExpr {
    -- Opaque predicate constraint (e.g. Malli :fn).
}

variant UnknownExpr : TypeExpr {
    -- Unconvertible form, preserved as string for debugging.
    original: String
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value FunctionSignature {
    -- The type contract of a function: ordered input types and a return type.
    -- Schema references within types are the basis for deriving data flow
    -- perspectives at projection time.
    inputs: List<TypeExpr>
    output: TypeExpr
}

value BoundaryFn {
    -- Summary of a public function in a module boundary.
    -- Not the full Function entity — just the contract-relevant fields.
    -- Appears in Boundary.functions to describe what a module provides.
    name: String
    id: Identifier?          -- NodeId of corresponding Function child, if any
    signature: FunctionSignature?
    doc: String?
}

value Boundary {
    -- A module's public contract: what it promises to the outside world.
    --
    -- The boundary is a manifest — it declares the module's public API
    -- and the data shapes it owns. Summaries, not entity references:
    -- BoundaryFn captures the contract-relevant slice of each function,
    -- and schema keys identify owned schemas by registry key.
    --
    -- Assembled from specification and implementation:
    --   - description: from spec surface description, namespace docstring,
    --     or entity description (first available, in that priority)
    --   - functions: public API operations (from spec surface provides,
    --     or inferred from implementation signatures)
    --   - schemas: registry keys of data shapes this module owns and
    --     publishes (consumers of these schemas depend on this module)
    --   - guarantees: from specification

    description: String?
    functions: List<BoundaryFn>
    schemas: List<Identifier>
    guarantees: List<String>?
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

enum EdgeKind { function_call | dispatches | schema_reference }
-- function_call:     A directly invokes B. A's source names B's var with
--                    invocation intent. The common case for function dependencies.
--
-- dispatches:        A polymorphically routes to B at runtime.
--                    A is a dispatch point, B is a handler. Stored once in the
--                    canonical direction (dispatch point → handler). The
--                    reverse reading — "B implements A" — is a projection
--                    concern, not a separate edge.
--
-- schema_reference:  A's type structure names B. Schema-to-schema keyword
--                    references within TypeExpr forms.
--
-- Projection perspectives:
--   Call graph (who invokes whom):
--     function_call edges: from → to (direct invocation)
--     dispatches edges: from → to (dispatch point routes to handler)
--   Dependency graph (who depends on whom):
--     function_call edges: from → to (caller depends on callee) — same direction
--     dispatches edges: to → from (handler depends on dispatch point) — flipped
--   Both perspectives use the same stored edges; projection controls direction.

entity Edge {
    -- Directed relationship between two leaf nodes.
    -- Edges are strictly leaf-to-leaf: both endpoints are Function
    -- or Schema nodes. Module-level relationships are derived by
    -- the projection layer through ancestor aggregation.
    --
    -- The canonical direction is always stored. For code edges (calls,
    -- dispatches) this is the invocation direction: caller → callee,
    -- dispatch point → handler. Projection may flip direction when
    -- rendering dependency perspectives.
    --
    -- EdgeKindEndpoints: the kind constrains valid endpoint types.
    --   function_call: from is Function, to is Function or Schema
    --     (a function may reference a var replaced by a schema node)
    --   dispatches: both endpoints are Function
    --     (dispatch point and handler are both functions)
    --   schema_reference: both endpoints are Schema
    from: Node
    to: Node
    kind: EdgeKind

    invariant NoSelfEdge {
        from != to
    }
}

entity Node {
    -- An entity in the system model.
    --
    -- Nodes represent both specification concepts and implementation
    -- artifacts in a unified graph. A node may exist from:
    --   spec-only: design-phase, no implementation yet
    --   impl-only: imperative shell, no spec needed
    --   both: specced functional core with implementation
    --
    -- Structural invariants (hold for all nodes in a well-formed model):
    --
    -- TreeStructure: each node has at most one parent, which exists in
    --   the model. The hierarchy forms a strict tree — no cycles.
    --
    -- LeafStrictness: Function and Schema nodes never have children.
    --
    -- SchemaReplacesFunction: when a var defines a schema, no function
    --   node exists for that var. A schema node takes its place.

    kind: Module | Function | Schema
    label: String

    -- Hierarchy
    parent: Node?
    children: Node with parent = this

    -- Derived
    is_leaf: children.count = 0
    is_root: parent = null

    invariant LeafStrictness {
        kind in {Function, Schema} implies children.count = 0
    }
}

variant Module : Node {
    -- A module in the system: directory, namespace, or specification scope.
    -- Organizes the tree hierarchy and defines module boundaries.
    --
    -- Three realization states:
    --   spec-only: has boundary from spec, no implementation children
    --   impl-only: has code children, boundary inferred from signatures
    --   both: spec provides the "what", impl children provide the "how"
    --
    -- ModuleBoundary: every module has a boundary. The build pipeline
    --   infers one from public function signatures when no spec or
    --   contract provides one explicitly. This ensures IO can always
    --   be derived from boundary functions at projection time.

    boundary: Boundary
}

variant Function : Node {
    -- An operation within a module.
    --
    -- Two sources:
    -- - Implementation: discovered from code analysis (var definitions).
    --   Has full details: doc, visibility, signature.
    -- - Specification: materialized from a spec provides operation.
    --   Has name and signature; private is always false (spec
    --   operations are by definition public).
    --
    -- For spec+impl modules, spec-derived functions may correspond
    -- to implementation-discovered functions. Correspondence is by name.
    doc: String?
    private: Boolean
    signature: FunctionSignature?
}

variant Schema : Node {
    -- A named schema definition within a namespace.
    -- When a var defines a schema, the function node for that var is
    -- removed and a schema node takes its place in the tree.
    --
    -- Schema nodes are owned by their parent module. They form part
    -- of that module's published data contract — other modules that
    -- reference these schemas take a dependency on the owning module.
    -- Private schemas are internal implementation details; public
    -- schemas appear in the module's boundary.
    schema_key: String
    form: TypeExpr
    doc: String?
    private: Boolean
}

entity Model {
    -- Complete system model. Immutable after construction.
    -- Combines specification and implementation into a unified graph
    -- where both are navigable with the same tools.
    --
    -- Structural invariants:
    --
    -- NoEmptyModules: modules without children are removed during
    --   build. Exception: spec-only modules with a boundary declaration
    --   are retained — they represent design-phase definitions that may
    --   have no child functions yet.
    --
    -- NoSelfEdges: every edge has from != to.
    --
    -- EdgeIntegrity: both endpoints of every edge exist in nodes.
    --
    -- LeafEdges: both endpoints of every edge are leaf nodes
    --   (Function or Schema). Module-level edges do not exist in
    --   the model — they are derived on demand by projection.
    --
    -- EdgeKindEndpoints: endpoint node kinds are constrained by
    --   edge kind (see EdgeKind enum and Edge entity).
    --
    -- SmartRootPruning: single-child module chains at the root are
    --   collapsed. The tree starts at the first module with multiple
    --   children or non-module children.
    --
    -- BoundaryFunctionConsistency: every spec provides operation has
    --   a corresponding Function child node. Spec operations are
    --   materialized as children during build, ensuring spec-only
    --   modules are navigable.

    nodes: Map<String, Node>   -- keyed by NodeId
    edges: List<Edge>

    -- Projections
    modules: nodes where kind = Module
    root_nodes: nodes where is_root
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant EdgeIntegrity {
    for e in Model.edges:
        e.from in Model.nodes and e.to in Model.nodes
}

invariant LeafEdges {
    for e in Model.edges:
        e.from.kind in {Function, Schema}
        and e.to.kind in {Function, Schema}
}

invariant EdgeKindEndpoints {
    for e in Model.edges:
        e.kind = dispatches implies
            (e.from.kind = Function and e.to.kind = Function)
        e.kind = schema_reference implies
            (e.from.kind = Schema and e.to.kind = Schema)
}

invariant TreeStructure {
    for n in Model.nodes:
        n.parent != null implies n.parent in Model.nodes
}

invariant NoEmptyImplModules {
    -- Modules without children are removed during build.
    -- Exception: spec-only modules with boundary declarations are retained.
    for n in Model.modules:
        n.children.count = 0 implies n.boundary.description != null
}
