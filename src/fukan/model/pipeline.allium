-- allium: 2
-- pipeline.allium
--
-- Scope: Model build pipeline — how a Model is constructed from
--   source analysis, and how it is checked for contract compliance
-- Includes: AnalysisResult shape, SourceAnalyzer contract,
--   contract compliance invariant
-- Excludes:
--   - The Model itself (see model/spec.allium)
--   - Language-specific analyzer internals (see analyzers/)
--   - Model state management (see infra/model.allium)

use "./spec.allium" as model

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value AnalysisResult {
    -- The language-agnostic output from each source analyzer.
    -- Each language analyzer (Clojure, Allium, future languages)
    -- independently produces an AnalysisResult from the same source path.
    -- Results are merged additively before the build step runs.
    --
    -- Implementation analyzers discover code structure: modules,
    -- symbols, schemas, dependencies.
    -- Specification analyzers discover design structure: entities,
    -- surfaces, fields, typed relationships.
    -- Both produce the same shape; the SourceAnalyzer contract
    -- defines the obligation.

    source_files: List<String>
    nodes: Map<String, model/Node>
    edges: List<model/Edge>
}

value LintViolation {
    -- A single contract violation: a cross-module call to a function
    -- not declared in the target module's boundary.
    from: String               -- NodeId of the calling function
    to: String                 -- NodeId of the called function (not in boundary)
    from_module: String        -- Module containing the caller (direct parent)
    to_module: String          -- Module containing the callee (direct parent)
    contract_fns: List<String> -- Function names the target module does export
}

value LintReport {
    -- Contract compliance report: violations and aggregate statistics.
    violations: List<LintViolation>
    stats: LintStats
}

value LintStats {
    -- Aggregate edge counts for a lint check.
    total_edges: Integer
    cross_module_edges: Integer
    violations: Integer
}

------------------------------------------------------------
-- Contracts
------------------------------------------------------------

contract SourceAnalyzer {
    -- Polymorphic role: any module that discovers structure from a
    -- source path by producing a language-agnostic AnalysisResult.
    --
    -- Fulfilled independently by implementation analyzers (code
    -- structure — scopes, symbols, dependencies) and specification
    -- analyzers (design structure — entities, surfaces, fields).
    -- Results are merged additively before the build step runs.

    analyzes: (src: SourcePath) -> AnalysisResult
        -- SourcePath is a filesystem directory path.
        -- Each fulfiller produces an independent AnalysisResult from
        -- the same source path. Fulfillers may read runtime state
        -- during analysis (e.g. loaded JVM namespaces).

    @invariant ParseFailureIsolation
        -- A single file's parse failure does not prevent analysis of
        -- other files. Failed files are silently excluded from the
        -- returned AnalysisResult.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant ContractCompliance {
    -- Every cross-module function call must target a function
    -- declared in the callee's direct-parent module boundary.
    --
    -- Module ownership: each function's module is its direct parent
    -- node. A call is cross-module when the caller's parent differs
    -- from the callee's parent. Only the callee's direct-parent
    -- boundary is checked — ancestor boundaries are not consulted.
    --
    -- Boundary matching uses BoundaryFn.id to match against the
    -- called function's NodeId. A module's boundary is enforceable
    -- only when at least one BoundaryFn has a non-nil id. Modules
    -- where no boundary function has an id are not subject to
    -- contract checking.

    for e in Model.edges where e.kind = function_call
            and e.to.kind = Function
            and e.from.parent != e.to.parent:
        let boundary_ids = e.to.parent.boundary.functions.id where id != null
        boundary_ids.count = 0 or e.to in boundary_ids
}
