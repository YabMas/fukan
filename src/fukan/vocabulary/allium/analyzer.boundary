-- boundary: 1

-- Per-file Allium AST → kernel content (with Allium::* tag applications)
-- analyzer. See analyzer.allium for the behavioural commitments —
-- declaration-order discipline, cross-module reference resolution,
-- event synthesis, stub creation.

use "../../model/spec.allium" as model
use "../../libs/allium/parser.allium" as parser

