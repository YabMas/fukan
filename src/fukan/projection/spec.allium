-- allium: 2
-- projection.allium
--
-- Scope: Projection — pure computation from (Model, options) to visible subgraph
-- Includes: Graph projection, entity details, breadcrumb paths, edge semantics
-- Excludes:
--   - Model construction (see model.allium)
--   - View rendering, UI state, interaction (see views.allium)

use "./model.allium" as model

------------------------------------------------------------
-- Given
------------------------------------------------------------

given {
    model: model/Model
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum Perspective { call_graph | dependency_graph }
-- call_graph:        "who invokes whom" — edges follow invocation direction.
--                    function_call: caller → callee. dispatches: dispatch point → handler.
-- dependency_graph:  "who depends on whom" — edges follow dependency direction.
--                    function_call: caller → callee (same). dispatches: handler → dispatch point (flipped).
--
-- The perspective determines how model edges are projected. Both use
-- the same stored edges; only dispatches edges change direction.

enum EdgeType { code_flow | schema_reference }
-- code_flow:           aggregated from model function_call + dispatches edges.
--                      Direction depends on active perspective.
-- schema_reference:    aggregated from model schema_reference edges.
--                      Direction is invariant across perspectives.

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value ViewNode {
    -- A node in the projected graph. Pure domain data — no UI state
    -- (selected?, highlighted?). The view layer adds those.
    id: String
    kind: module | function | schema
    label: String
    parent: String?
    expandable: Boolean
    has_private_children: Boolean
    expanded: Boolean
    showing_private: Boolean
    child_count: Integer
    private: Boolean?
    schema_key: String?    -- present for schema nodes
}

value ViewEdge {
    id: String
    from: String
    to: String
    edge_type: EdgeType
    kind: model/EdgeKind           -- preserved from model for detail views
}

value Projection {
    -- The visible subgraph for a given view context.
    -- This is the primary output of the projection layer.
    nodes: List<ViewNode>
    edges: List<ViewEdge>
}

value PathSegment {
    -- One step in a breadcrumb path from root to entity.
    id: String?     -- null for root
    label: String   -- short display label from the node
}

value DepInfo {
    -- Dependency count and display label for a related entity.
    count: Integer
    label: String
}

value SchemaRegistryEntry {
    -- A named schema from the one-level registry.
    form: model/TypeExpr
    doc: String?
}

value DataflowData {
    -- Schema types flowing across an entity's boundary.
    -- Derived from function signatures:
    --   function → schema refs in input params are inputs,
    --              schema refs in return type are outputs
    --   module   → accumulated IO of its boundary functions
    -- Each schema key carries ownership (parent module), so
    -- "input type X owned by module Y" = data flows from Y.
    inputs: List<model/Schema>
    outputs: List<model/Schema>
}

value EntityDetail {
    -- Normalized detail structure for any node entity.
    --
    -- InterfaceDispatch: interface extraction differs by kind:
    --   module   → FnListInterface from boundary functions
    --   function → FnInlineInterface from function signature
    --   schema   → SchemaDefInterface from schema form + one-level registry
    --
    -- SameKindAggregation: deps and dependents are aggregated to the
    --   same kind as the entity. A module's deps are other modules;
    --   a function's deps are other functions. Self-subtree is excluded.
    label: String
    kind: module | function | schema
    parent: ParentRef?
    description: String?
    guarantees: List<String>?  -- spec-derived invariant promises
    interface: InterfaceData?
    schemas: List<model/Schema>?
    dataflow: DataflowData?
    deps: Map<String, DepInfo>
    dependents: Map<String, DepInfo>
}

value ParentRef {
    -- Reference to a parent entity for navigation and display.
    id: String
    label: String
}

value EdgeDetail {
    -- Detail structure for an aggregated edge: the underlying
    -- leaf-level relationships that cross this dependency.
    -- For code_flow edges: function calls and/or dispatch relationships.
    -- For schema_reference edges: schema_reference relationships.
    --
    -- A single aggregated edge may combine multiple model edge kinds
    -- (e.g. code_flow aggregates both function_call and dispatches).
    -- The called_fns/dispatched_fns/schema_refs split captures which
    -- model edge kinds contribute, rather than a single kind field.
    detail_kind: edge         -- discriminant for EntityDetail | EdgeDetail union
    edge_type: EdgeType
    label: String
    called_fns: List<model/Function>?      -- code_flow edges (function_call kind)
    dispatched_fns: List<model/Function>?  -- code_flow edges (dispatches kind)
    schema_refs: List<model/Schema>?       -- schema_reference edges
}

------------------------------------------------------------
-- Interface Data (Sum Type)
------------------------------------------------------------

value InterfaceData {
    -- Public interface of an entity, discriminated by display format.
    -- Each variant carries typed items appropriate to its format.
    type: FnListInterface | FnInlineInterface | SchemaDefInterface | NameListInterface
}

value FnListInterface {
    -- Boundary functions with optional signatures (modules).
    items: List<model/Function>
}

value FnInlineInterface {
    -- Single function signature (functions).
    items: List<model/FunctionSignature>
}

value SchemaDefInterface {
    -- Schema form with one-level registry (schemas).
    items: List<model/TypeExpr>
    registry: Map<String, SchemaRegistryEntry>?
}

value NameListInterface {
    -- Bare names without schemas (interface nodes).
    items: List<String>
}

------------------------------------------------------------
-- Search and Overview
------------------------------------------------------------

value SearchResult {
    -- A single search match: node identity and location.
    id: String
    kind: module | function | schema
    label: String
    parent: String?
}

value ModelOverview {
    -- Summary statistics for the loaded model.
    total_nodes: Integer
    total_edges: Integer
    by_kind: Map<String, Integer>   -- node kind label → count
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------
--
-- Projection is pure computation. The callable shapes live in
-- projection/spec.boundary (navigate, inspect, search, overview).
-- The load-bearing semantics are the structural promises these
-- callables must satisfy — captured as invariants below.

invariant PerspectiveControl {
    -- Perspective determines edge-direction interpretation.
    -- call_graph shows invocation flow; dependency_graph flips
    -- dispatches edges to show dependency flow. When omitted,
    -- navigate defaults to call_graph.
    --
    -- For dispatches edges:
    --   call_graph:       from → to (canonical, invocation direction)
    --   dependency_graph: to → from (flipped, dependency direction)
    -- function_call and schema_reference edges are unaffected.
}

invariant EdgeTypeFiltering {
    -- visible_edge_types controls which edge kinds appear in the
    -- projection. When omitted, navigate defaults to
    -- { code_flow, schema_reference }. Filtering happens before
    -- aggregation so layout accounts for the visible edge set.
}

invariant LeafNodeFiltering {
    -- The active edge type also determines which leaf node kinds
    -- are visible:
    --   code_flow only:        function nodes visible, schema nodes hidden
    --   schema_reference only: schema nodes visible, function nodes hidden
    --   both:                  all leaf nodes visible
    -- Module nodes are always visible regardless of edge type.
    -- Filtering applies after visible-set computation but before
    -- edge aggregation, so edges aggregate correctly to the
    -- filtered set.
}

invariant ModuleViewBoundingBox {
    -- When navigating to a module, ONLY entities inside that module
    -- appear. External entities are never shown. Edges that would
    -- cross the bounding box are not rendered. To see external
    -- relationships, navigate to a common ancestor.
}

invariant DefaultCollapsed {
    -- Child modules appear as opaque nodes by default. Their children
    -- are not visible until the user explicitly expands them. There
    -- is no automatic drill-down.
}

invariant RecursiveExpansion {
    -- Expanding a module reveals its direct children. Among those,
    -- child modules are themselves collapsed unless independently
    -- expanded. Any nesting depth is supported.
}

invariant ViewAsRoot {
    -- The viewed module is implicitly expanded — its children are
    -- always visible. This is what "viewing a module" means.
}

invariant NoAncestorDescendantEdges {
    -- Edges between a module and its own descendants are suppressed.
    -- The parent-child relationship is implicit in nesting.
}

invariant PrivateVisibility {
    -- Within an expanded module, private children are hidden unless
    -- the module is also in show_private.
}

invariant ModuleEndpoints {
    -- Aggregated edges may terminate at collapsed modules. A
    -- collapsed module acts as a summary node for all its hidden
    -- descendants. Expanding it "breaks apart" edges that terminated
    -- at it; collapsing merges them back.
}

invariant ConsistentAggregation {
    -- Expanding then immediately collapsing a module produces the
    -- same projection as before. The mechanism is reversible.
}

invariant LeafViewNoBoundingBox {
    -- When navigating to a leaf entity, related entities from
    -- anywhere in the model are shown — there is no spatial
    -- constraint. Only edges involving the selected entity appear.
}

invariant SemanticGrouping {
    -- Edge aggregation groups model semantics into projection edge
    -- types:
    --   function_call + dispatches → code_flow
    --   schema_reference           → schema_reference
    -- Each projection type is aggregated, deduplicated, and
    -- subsumed independently.
}

invariant ClosestVisibleAncestor {
    -- For a node N, walk up the parent chain (including N itself)
    -- until a node in the visible set is found. If N is visible, its
    -- CVA is itself. If N is inside a collapsed module M, its CVA is
    -- M (assuming M is visible). If N is outside the view entirely,
    -- it has no CVA.
}

invariant PrivateInheritance {
    -- When a public node's cross-module dependencies are mediated
    -- through private nodes, the public node inherits those
    -- dependencies as synthetic edges. The private node itself
    -- remains hidden. Applies to all edge kinds.
}

invariant Subsumption {
    -- A module-level edge is redundant when a visible descendant
    -- already represents the same connection. Edge A→T is subsumed
    -- (dropped) if there exists edge D→T where D is a strict visible
    -- descendant of A. The more specific edge is the representative;
    -- the less specific one is noise.
}
