{:paths ["src" "." "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.11.1"}
        http-kit/http-kit {:mvn/version "2.7.0"}
        metosin/reitit {:mvn/version "0.7.0"}
        hiccup/hiccup {:mvn/version "2.0.0-RC2"}
        cheshire/cheshire {:mvn/version "5.12.0"}
        dev.data-star.clojure/http-kit {:mvn/version "1.0.0-RC7"}
        metosin/malli {:mvn/version "0.16.4"}
        instaparse/instaparse {:mvn/version "1.5.0"}
        org.babashka/sci {:mvn/version "0.8.41"}
        clj-kondo/clj-kondo {:mvn/version "2024.03.13"}
        ;; Cozo query engine (datascript→Cozo migration). JNI native lib auto-downloads
        ;; on first use to ~/.cozo_java_native_lib/.
        io.github.cozodb/cozo-clj {:mvn/version "0.7.5"}}
 :aliases
 {:run {:main-opts ["-m" "fukan.core"]}
  :dev {:extra-paths ["dev"]
       :extra-deps {io.github.tonsky/clj-reload {:mvn/version "0.7.1"}
}}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                      org.clojure/test.check {:mvn/version "1.1.1"}}
         :main-opts ["-m" "cognitect.test-runner"]}
  ;; Regenerate the clj-kondo instance-constructor hooks from a defstructure scan
  ;; (`tasks.kondo`, reachable via the `.` classpath root). Run after adding or
  ;; removing a structure; the `generated-config-file-is-current` test guards drift.
  :kondo {:main-opts ["-m" "tasks.kondo"]}
  :nrepl
  {:extra-deps {nrepl/nrepl       {:mvn/version "1.3.0"}
                cider/cider-nrepl {:mvn/version "0.50.3"}}
   :main-opts  ["--main" "nrepl.cmdline"
                "--middleware" "[cider.nrepl/cider-middleware]"
                "--port" "7889"]}}}
